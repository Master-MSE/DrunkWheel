code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;


// Varyings
varying vec3 var_test;

instance uniform float seed = 0;
global uniform float tauxalcool;
instance uniform float Alpha = 0.60000002384186;
instance uniform float Metallic = 1;
instance uniform float Roughness = 1;



void vertex() {
// Input:2
	vec3 n_out2p0 = VERTEX;
	float n_out2p1 = n_out2p0.r;
	float n_out2p2 = n_out2p0.g;
	float n_out2p3 = n_out2p0.b;


// Input:3
	float n_out3p0 = TIME;


// FloatFunc:4
	float n_out4p0 = abs(n_out3p0);


// FloatOp:15
	float n_in15p1 = 3.00000;
	float n_out15p0 = n_out4p0 * n_in15p1;


// FloatOp:14
	float n_out14p0 = n_out2p2 * n_out15p0;


// FloatFunc:12
	float n_out12p0 = sin(n_out14p0);


// FloatOp:16
	float n_in16p1 = 0.20000;
	float n_out16p0 = n_out12p0 * n_in16p1;


// FloatOp:13
	float n_out13p0 = n_out16p0 + n_out2p1;


// FloatOp:11
	float n_in11p1 = 0.00000;
	float n_out11p0 = n_out13p0 + n_in11p1;


// Input:19
	float n_out19p0 = TIME;


// FloatParameter:20
	float n_out20p0 = seed;


// FloatConstant:27
	float n_out27p0 = 6.283000;


// FloatOp:25
	float n_out25p0 = n_out20p0 * n_out27p0;


// FloatOp:23
	float n_out23p0 = n_out19p0 + n_out25p0;


// FloatFunc:18
	float n_out18p0 = sin(n_out23p0);


// FloatParameter:21
	float n_out21p0 = tauxalcool;


// FloatOp:24
	float n_in24p1 = 0.50000;
	float n_out24p0 = n_out21p0 * n_in24p1;


// FloatOp:22
	float n_out22p0 = n_out18p0 * n_out24p0;


// FloatOp:17
	float n_out17p0 = n_out11p0 + n_out22p0;


// VectorCompose:6
	vec3 n_out6p0 = vec3(n_out17p0, n_out2p2, n_out2p3);


// Output:0
	VERTEX = n_out6p0;


	var_test = vec3(0.0);
}

void fragment() {
// ColorConstant:2
	vec4 n_out2p0 = vec4(1.000000, 0.000000, 0.000000, 1.000000);


// FloatParameter:3
	float n_out3p0 = Alpha;


// FloatParameter:4
	float n_out4p0 = Metallic;


// FloatParameter:5
	float n_out5p0 = Roughness;


// Output:0
	ALBEDO = vec3(n_out2p0.xyz);
	ALPHA = n_out3p0;
	METALLIC = n_out4p0;
	ROUGHNESS = n_out5p0;


}
